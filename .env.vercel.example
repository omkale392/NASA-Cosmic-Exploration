# ──────────────────────────────────────────────────────────────────────────────
# Vercel Environment Variables Template
# ──────────────────────────────────────────────────────────────────────────────
# Copy the values below into your Vercel project's Environment Variables UI:
#   Dashboard → Project → Settings → Environment Variables
#
# Set each variable for: Production, Preview, AND Development (where needed).
# DO NOT commit actual secret values — only reference this example file.
# ──────────────────────────────────────────────────────────────────────────────

# ── Backend (Serverless Function) ─────────────────────────────────────────────

# Your NASA API key (get one free at https://api.nasa.gov/)
# Without this the backend falls back to DEMO_KEY (very low rate limits)
NASA_API_KEY=your_nasa_api_key_here

# Groq API key for AI mission briefings (https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Comma-separated list of frontend origins allowed by CORS.
# Replace <your-project>.vercel.app with your actual Vercel deployment URL.
# Add your custom domain here too if you have one.
CORS_ORIGIN=https://<your-project>.vercel.app,https://<your-project>-git-main-<username>.vercel.app

# ── Frontend (Vite Build) ─────────────────────────────────────────────────────

# The public URL of your backend API on Vercel.
# Since the frontend and API are co-deployed, use a relative /api path
# so the same URL works in production, preview, and local dev.
# Set this to /api in your Vercel project settings.
VITE_API_URL=/api

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
