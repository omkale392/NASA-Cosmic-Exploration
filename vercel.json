{
  "version": 2,
  "outputDirectory": "frontend/dist",
  "framework": null,
  "functions": {
    "api/index.ts": { "maxDuration": 30, "memory": 512 }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": { "NODE_ENV": "production" }
}