{
  "version": 2,
  "outputDirectory": "frontend/dist",
  "framework": null,
  "buildCommand": "npm install && cd frontend && npm install && npm run build",
  "functions": {
    "api/index.ts": { "maxDuration": 30, "memory": 512 }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}